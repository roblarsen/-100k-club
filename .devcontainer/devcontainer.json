{
  "name": "Comic Data Automation",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.10-bullseye",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.formatting.provider": "black",
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ]
    }
  },
  "postCreateCommand": "pip install --upgrade pip && pip install playwright google-genai requests && playwright install --with-deps chromium"
}