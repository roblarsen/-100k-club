{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "lib": ["ES2017"],
    "allowJs": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "strict": false,
    "noImplicitAny": false,
    "sourceMap": true,
    "outDir": "./dist-test",
    "baseUrl": ".",
    "types": ["jest", "node"]
  },
  "include": [
    "__tests__/**/*",
    "core/**/*",
    "record-sales/scripts/**/*",
    "timeline/scripts/inflation.ts"
  ]
}
